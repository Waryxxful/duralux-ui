{
  "name": "@duralux/ui",
  "version": "0.1.0",
  "description": "Librería de componentes React + Duralux CSS",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "prepare": "vite build",
    "dev:demo": "vite --config demo/vite.config.js",
    "preview:demo": "vite preview --config demo/vite.config.js"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "apexcharts": "^5.15.2",
    "react-apexcharts": "^2.1.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.5",
    "vite": "^6.0.5"
  },
  "sideEffects": false
}
