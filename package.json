{
  "name": "@duralux/ui",
  "version": "1.0.0",
  "description": "Librer\u00eda de componentes React + Duralux CSS",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/styles/grancrm-ui.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles/grancrm-ui.css": "./dist/styles/grancrm-ui.css",
    "./styles/feather-icons.css": "./dist/styles/feather-icons.css",
    "./styles.css": "./dist/styles/grancrm-ui.css",
    "./theme.css": "./dist/theme.css",
    "./theme.min.css": "./dist/theme.min.css",
    "./bootstrap.css": "./dist/bootstrap.css",
    "./bootstrap.min.css": "./dist/bootstrap.min.css"
  },
  "files": [
    "dist",
    "scss"
  ],
  "scripts": {
    "build:scss": "node scripts/build-scss.mjs",
    "build": "vite build && node scripts/copy-styles.mjs && node scripts/write-index-dts.mjs && npm run build:scss",
    "prepare": "npm run build",
    "dev:demo": "vite --config demo/vite.config.js",
    "preview:demo": "vite preview --config demo/vite.config.js"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "apexcharts": "^5.15.2",
    "react-apexcharts": "^2.1.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.5",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^5.0.3"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Waryxxful/duralux-ui.git"
  }
}
